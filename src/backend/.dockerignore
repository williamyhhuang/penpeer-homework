# ── 版控與 CI ─────────────────────────────────────────────────────────────────
.git
.gitignore

# ── 文件（不需進 image）─────────────────────────────────────────────────────────
*.md
docs/

# ── 本地開發產物 ───────────────────────────────────────────────────────────────
bin/
tmp/
vendor/

# ── 測試覆蓋率報告 ─────────────────────────────────────────────────────────────
coverage.out
coverage.html
*.test

# ── 敏感設定（由 docker-compose env 注入，不打包進 image）──────────────────────
.env
.env.*

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
