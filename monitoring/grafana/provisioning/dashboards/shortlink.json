{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.2" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "ShortLink 服務監控 Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(shortlink_http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ],
      "title": "HTTP 請求速率 (RPS by path)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(shortlink_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "P50 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(shortlink_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "P95 {{path}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(shortlink_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "P99 {{path}}"
        }
      ],
      "title": "HTTP 延遲 P50 / P95 / P99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0, "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }},
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 9 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(shortlink_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(shortlink_http_requests_total[5m])) * 100",
          "legendFormat": "5xx 錯誤率"
        }
      ],
      "title": "5xx 錯誤率 (%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 9 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "shortlink_http_requests_in_flight",
          "legendFormat": "In-Flight 請求"
        }
      ],
      "title": "In-Flight 請求數",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(shortlink_http_requests_total{status_code=\"429\"}[1m]))",
          "legendFormat": "429 Rate Limit 命中"
        }
      ],
      "title": "429 Rate Limit 命中速率",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 200,
      "title": "業務指標",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(shortlink_redirect_total[1m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ],
      "title": "Redirect 速率（依結果分類）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0, "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "green", "value": 90 }
          ]
        }},
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(shortlink_cache_operations_total{result=\"hit\"}[5m])) / sum(rate(shortlink_cache_operations_total{operation=\"get\"}[5m])) * 100",
          "legendFormat": "Redis 命中率"
        }
      ],
      "title": "Redis 快取命中率 (%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0, "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]
        }},
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(shortlink_bloom_filter_checks_total{result=\"reject\"}[5m])) / sum(rate(shortlink_bloom_filter_checks_total[5m])) * 100",
          "legendFormat": "Bloom 阻擋率"
        }
      ],
      "title": "Bloom Filter 阻擋率 (%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 23 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(shortlink_links_created_total[5m])",
          "legendFormat": "短網址建立速率"
        }
      ],
      "title": "短網址建立速率",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 23 },
      "id": 14,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(shortlink_clicks_recorded_total[1m])) by (result)",
          "legendFormat": "點擊記錄 {{result}}"
        }
      ],
      "title": "點擊事件記錄速率",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 23 },
      "id": 15,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(shortlink_singleflight_dedup_total[1m])",
          "legendFormat": "Singleflight 去重"
        },
        {
          "expr": "rate(shortlink_null_cache_evictions_total[5m])",
          "legendFormat": "Null Cache 淘汰"
        }
      ],
      "title": "Singleflight 去重 & Null Cache 淘汰",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 300,
      "title": "PostgreSQL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 29 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "Active 連線"
        },
        {
          "expr": "pg_stat_activity_count{state=\"idle\"}",
          "legendFormat": "Idle 連線"
        }
      ],
      "title": "PostgreSQL 連線數",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 29 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"shortlink\"}[1m])",
          "legendFormat": "Commit TPS"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"shortlink\"}[1m])",
          "legendFormat": "Rollback TPS"
        }
      ],
      "title": "PostgreSQL TPS（Commit / Rollback）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0, "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 80 },
            { "color": "green", "value": 95 }
          ]
        }},
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 29 },
      "id": 22,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"shortlink\"} / (pg_stat_database_blks_hit{datname=\"shortlink\"} + pg_stat_database_blks_read{datname=\"shortlink\"} + 1) * 100",
          "legendFormat": "Buffer Cache Hit"
        }
      ],
      "title": "PG Buffer Cache Hit Ratio (%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 29 },
      "id": 23,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"shortlink\"}",
          "legendFormat": "DB 大小"
        }
      ],
      "title": "PostgreSQL DB 大小",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 400,
      "title": "Redis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 39 },
      "id": 30,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used Memory"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "Max Memory"
        }
      ],
      "title": "Redis 記憶體使用量",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 39 },
      "id": 31,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[1m])",
          "legendFormat": "Keyspace Hits"
        },
        {
          "expr": "rate(redis_keyspace_misses_total[1m])",
          "legendFormat": "Keyspace Misses"
        }
      ],
      "title": "Redis Keyspace Hits / Misses",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 39 },
      "id": 32,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected Clients"
        }
      ],
      "title": "Redis Connected Clients",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 39 },
      "id": 33,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "redis_db_keys{db=\"db0\"}",
          "legendFormat": "Key 數量"
        }
      ],
      "title": "Redis Key 總數",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 43 },
      "id": 34,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total[1m])",
          "legendFormat": "Eviction 速率"
        }
      ],
      "title": "Redis Eviction 速率",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "id": 500,
      "title": "Container Resources (cAdvisor)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "id": 40,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"backend|postgres|redis|loadbalancer\",id!=\"/\"}[1m]) * 100",
          "legendFormat": "{{container_label_com_docker_compose_service}} CPU"
        }
      ],
      "title": "容器 CPU 使用率 (%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "id": 41,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"backend|postgres|redis|loadbalancer\",id!=\"/\"}",
          "legendFormat": "{{container_label_com_docker_compose_service}} Memory"
        }
      ],
      "title": "容器記憶體使用量",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 57 },
      "id": 42,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=\"loadbalancer\"}[1m])",
          "legendFormat": "LB 接收"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=\"loadbalancer\"}[1m])",
          "legendFormat": "LB 發送"
        }
      ],
      "title": "Load Balancer 網路 I/O",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["shortlink", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Data Source"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ShortLink 服務監控",
  "uid": "shortlink-monitoring-v1",
  "version": 1
}
