# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost       # 資料庫主機（Docker 內部服務名稱為 postgres）
DB_PORT=5432            # 資料庫連接埠
DB_USER=postgres        # 資料庫使用者名稱
DB_PASSWORD=            # 資料庫密碼（請填入實際密碼，正式環境務必使用強密碼）
DB_NAME=shortlink       # 資料庫名稱

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost    # Redis 主機（Docker 內部服務名稱為 redis）
REDIS_PORT=6379         # Redis 連接埠

# ── Backend Server ────────────────────────────────────────────────────────────
SERVER_PORT=8080        # 後端 HTTP 監聽連接埠

# ── Null Cache 水位管控 ────────────────────────────────────────────────────────
NULL_CACHE_MAX_KEYS=10000    # 水位閥值：null cache key 超過此數量觸發淘汰
NULL_CACHE_EVICT_COUNT=1000  # 每次淘汰的 key 數量（淘汰最舊的 N 筆）

# ── Rate Limit（per-IP，redirect 路徑）────────────────────────────────────────
RATE_LIMIT_RPS=30       # 每秒允許的請求數
RATE_LIMIT_BURST=60     # 短時間突發上限（單一窗口最多請求數）

# ── Bloom Filter ───────────────────────────────────────────────────────────────
BLOOM_CAPACITY=1000000  # 預期短碼最大數量（影響記憶體用量與誤判率）
