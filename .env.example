# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost       # 資料庫主機（Docker 內部服務名稱為 postgres）
DB_PORT=5432            # 資料庫連接埠
DB_USER=postgres        # 資料庫使用者名稱
DB_PASSWORD=            # 資料庫密碼（請填入實際密碼，正式環境務必使用強密碼）
DB_NAME=shortlink       # 資料庫名稱

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost    # Redis 主機（Docker 內部服務名稱為 redis）
REDIS_PORT=6379         # Redis 連接埠

# ── Backend Server ────────────────────────────────────────────────────────────
SERVER_PORT=8080        # 後端 HTTP 監聽連接埠
